<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mall4j 商城启动器"
        Width="520" Height="760"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- 颜色定义 -->
        <Color x:Key="PrimaryColor">#07C160</Color>
        <Color x:Key="PrimaryDark">#06AD56</Color>
        <Color x:Key="BgColor">#FFFFFF</Color>
        <Color x:Key="CardBg">#F7F8FA</Color>
        <Color x:Key="TextPrimary">#1A1A1A</Color>
        <Color x:Key="TextSecondary">#999999</Color>
        <Color x:Key="BorderColor">#E5E5E5</Color>
        <Color x:Key="SuccessColor">#07C160</Color>
        <Color x:Key="ErrorColor">#FA5151</Color>
        <Color x:Key="WarningColor">#FFC300</Color>
        <Color x:Key="StepPending">#DDDDDD</Color>
        <Color x:Key="StepRunning">#07C160</Color>

        <!-- 画刷 -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#07C160"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#06AD56"/>
        <SolidColorBrush x:Key="BgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#F7F8FA"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#999999"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#07C160"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FA5151"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFC300"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>

        <!-- 输入框样式 -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#F7F8FA"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 密码框样式 -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#F7F8FA"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主按钮样式 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#07C160"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#06AD56"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#059A4C"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#B8E6C8"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 次要按钮样式 -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#F7F8FA"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBEBEB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 标题栏按钮 -->
        <Style x:Key="TitleButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#1A1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 步骤圆点转换器模拟 -->
        <!-- 简约滚动条样式 -->
        <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Visible"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="PanningMode" Value="VerticalOnly"/>
        </Style>
    </Window.Resources>

    <!-- 主容器 -->
    <Border CornerRadius="12" Background="#FFFFFF">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Color="#40000000" Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 标题栏 -->
                <RowDefinition Height="Auto"/>  <!-- 标题区 -->
                <RowDefinition Height="Auto"/>  <!-- 配置区 -->
                <RowDefinition Height="*"/>     <!-- 步骤 + 日志区 -->
                <RowDefinition Height="Auto"/>  <!-- 按钮区 -->
            </Grid.RowDefinitions>

            <!-- ===== 1. 标题栏（拖拽区域） ===== -->
            <Border Grid.Row="0" Height="32" Background="Transparent">
                <Grid>
                    <TextBlock x:Name="titleBar" Text="Drag here to move"
                               FontSize="12" Foreground="Transparent"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                        <Button x:Name="btnMinimize" Content="─" Style="{StaticResource TitleButton}"/>
                        <Button x:Name="btnClose" Content="✕" Style="{StaticResource TitleButton}" Foreground="#FA5151"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== 2. 标题区 ===== -->
            <Border Grid.Row="1" Padding="0,8,0,16">
                <StackPanel HorizontalAlignment="Center">
                    <!-- 图标 -->
                    <Border Width="56" Height="56" CornerRadius="14" Background="#07C160" Margin="0,0,0,10">
                        <TextBlock Text="M" FontSize="28" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontFamily="Microsoft YaHei UI"/>
                    </Border>
                    <!-- 标题 -->
                    <TextBlock Text="Mall4j Launcher"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#1A1A1A"
                               HorizontalAlignment="Center"
                               FontFamily="Microsoft YaHei UI"/>
                    <TextBlock Text="Yami Shop v0.0.1 - One-click Dev Startup"
                               FontSize="12" Foreground="#999999"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ===== 3. 配置区 ===== -->
            <Border Grid.Row="2" Background="#F7F8FA" Padding="20,14" Margin="20,0,20,12" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 配置标题 -->
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                               Text="Config"
                               FontSize="13" FontWeight="Bold"
                               Foreground="#333333" Margin="0,0,0,10"/>

                    <!-- MySQL 用户名 -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="MySQL User"
                               FontSize="13" Foreground="#666666"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             x:Name="txtMysqlUser"
                             Text="root"
                             Style="{StaticResource ModernTextBox}" Margin="0,0,8,0"/>

                    <!-- MySQL 连接测试按钮 -->
                    <Button Grid.Row="1" Grid.Column="2"
                            x:Name="btnTestDb"
                            Content="Test"
                            Style="{StaticResource SecondaryButton}"
                            Width="80" Height="36"/>

                    <!-- MySQL 密码 -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="MySQL Password"
                               FontSize="13" Foreground="#666666"
                               VerticalAlignment="Center"/>
                    <!-- Password input (PasswordBox + visible TextBox toggle) -->
                    <Grid Grid.Row="2" Grid.Column="1" Margin="0,8,8,0">
                        <PasswordBox x:Name="txtMysqlPass"
                                     Style="{StaticResource ModernPasswordBox}"/>
                        <TextBox x:Name="txtMysqlPassVisible"
                                 Style="{StaticResource ModernTextBox}"
                                 Visibility="Collapsed"/>
                    </Grid>

                    <CheckBox Grid.Row="2" Grid.Column="2"
                              x:Name="chkShowPwd"
                              Content="Show"
                              FontSize="12" Foreground="#999999"
                              VerticalAlignment="Center" Margin="0,8,0,0"/>
                </Grid>
            </Border>

            <!-- ===== 4. 主内容区（步骤 + 日志） ===== -->
            <Grid Grid.Row="3" Margin="20,0,20,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="6*"/>
                    <RowDefinition Height="4*"/>
                </Grid.RowDefinitions>

                <!-- 步骤进度面板 -->
                <Border Grid.Row="0" Background="#F7F8FA" CornerRadius="10" Padding="12,8" Margin="0,0,0,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Steps" FontSize="12" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,4"/>

                        <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScrollViewer}">
                            <ItemsControl x:Name="stepList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,1,0,1" Padding="2,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="18" Height="18" CornerRadius="9"
                                                        Background="{Binding StatusColor}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusIcon}"
                                                               FontSize="10" Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                           FontSize="12" Foreground="#333333"
                                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                                                           FontSize="10" Foreground="{Binding StatusTextColor}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- 日志输出 -->
                <Border Grid.Row="1" Background="#1A1A2E" CornerRadius="10" Padding="12,10" MinHeight="120">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Log" FontSize="12" FontWeight="Bold" Foreground="#AAAAAA"/>
                            <Button Grid.Column="1" x:Name="btnClearLog" Content="Clear" Style="{StaticResource SecondaryButton}" Height="22" Width="46" FontSize="11"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScrollViewer}">
                            <TextBox x:Name="txtLog"
                                     Background="Transparent"
                                     Foreground="#CCCCCC"
                                     FontSize="11"
                                     FontFamily="Consolas"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Padding="0,2,0,0"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== 5. 按钮区 ===== -->
            <Border Grid.Row="4" Padding="20,8,20,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 状态指示 -->
                    <TextBlock Grid.Column="0" x:Name="lblStatus"
                               Text="Ready"
                               FontSize="13" Foreground="#07C160"
                               VerticalAlignment="Center"
                               FontFamily="Microsoft YaHei UI"/>

                    <!-- 结束按钮（彻底关闭 + 释放端口） -->
                    <Button Grid.Column="1" x:Name="btnEnd"
                            Content="End"
                            Width="100" Margin="0,0,10,0"
                            IsEnabled="False">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Foreground" Value="#FA5151"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFE5E5"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Setter Property="Background" Value="#F0F0F0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 启动按钮 -->
                    <Button Grid.Column="2" x:Name="btnStart"
                            Content="Start"
                            Style="{StaticResource PrimaryButton}"
                            Width="130"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
